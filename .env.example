# --- 1. Supabase (Database & Auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# --- 2. Upstash Redis (BullMQ & Cache) ---
# BullMQ requires the rediss:// (standard Redis protocol) URL
UPSTASH_REDIS_URL=rediss://default:[TOKEN]@...
# Next.js Server Components / Edge use REST
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- 3. AI Platform Keys (Monitoring & Parsing) ---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# --- 4. Special Differentiators (Phase 6) ---
# Required for AI Volume (Google Trends) and Google AI Overviews
SERPAPI_KEY=

# --- 5. System Security ---
# A random secret to protect the /api/cron/dispatch endpoint
CRON_SECRET=